# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
wheels/

# ---- Virtual environments ----
.venv/
venv/
env/

# ---- Test & type-check caches / coverage ----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.hypothesis/

# ---- Local environment / secrets (never commit real values) ----
.env
.env.*
!.env.example

# ---- User profile data (PII); root-anchored so it never matches nested app/.../data/ ----
/DATA/

# ---- Node (root level; frontend/ keeps its own .gitignore) ----
node_modules/

# ---- IDEs / editors ----
.idea/
*.iml
*.swp
*~

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Agent / assistant tooling (not part of the application) ----
.claude/
CLAUDE.md
.agents/
skills-lock.json

# ---- Personal documentation (local only; not part of the published project) ----
/DOCUMENTATION/
/docs/
