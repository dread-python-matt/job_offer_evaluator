# Copy to `.env` and fill in real values. NEVER commit the real `.env`.

# --- LLM provider ---
# Which provider's org-level usage/cost wiring to use: "gemini" or "openai".
LLM_PROVIDER=gemini
# Inference keys (used for scoring/translation). Set the one(s) you use.
GEMINI_API_KEY=
OPENAI_API_KEY=
# Organization Admin key (sk-admin-...) with the `api.usage.read` scope. Required
# only to read spend for the budget feature; leave blank to disable spend tracking.
OPENAI_ADMIN_KEY=

# --- Database ---
# Postgres connection (the `offers` table is owned by the external scraper).
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME

# --- Optional tuning (defaults shown) ---
# Seeds the budget limit on first run only; afterwards the DB owns it (set via API).
DEFAULT_BUDGET_USD=5.0
# Max offers scored by the AI in parallel per match request.
AI_MATCH_CONCURRENCY=10
# Set true to log raw LLM HTTP traffic (prompts/responses) — keep OFF in production.
LLM_DEBUG=false
# Comma-separated allowed CORS origins.
CORS_ORIGINS=http://localhost:4200
