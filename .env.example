# Copy to `.env` and fill in real values. NEVER commit the real `.env`.

# --- LLM provider ---
# Which provider's org-level usage/cost wiring to use: "gemini" or "openai".
LLM_PROVIDER=gemini
# Inference keys (used for scoring/translation). Set the one(s) you use.
GEMINI_API_KEY=
OPENAI_API_KEY=
# Organization Admin key (sk-admin-...) with the `api.usage.read` scope. Required
# only to read spend for the budget feature; leave blank to disable spend tracking.
OPENAI_ADMIN_KEY=

# --- Database ---
# Postgres connection (the `offers` table is owned by the external scraper).
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME

# --- Optional tuning (defaults shown) ---
# Seeds the budget limit on first run only; afterwards the DB owns it (set via API).
DEFAULT_BUDGET_USD=5.0
# Seconds to cache the provider spend figure used by the budget gate.
BUDGET_SPEND_CACHE_TTL_SECONDS=60.0
# Block AI matches when spend can't be read (fail-closed). Default false (fail-open).
BUDGET_FAIL_CLOSED=false
# Seconds to cache the provider's available-models list.
MODELS_CACHE_TTL_SECONDS=300.0
# Max offers scored by the AI in parallel per match request.
AI_MATCH_CONCURRENCY=10
# Timeout (seconds) for outbound LLM/provider HTTP calls.
LLM_TIMEOUT_SECONDS=60.0
# Set true to log raw LLM HTTP traffic (prompts/responses) — keep OFF in production.
LLM_DEBUG=false
# Comma-separated allowed CORS origins.
CORS_ORIGINS=http://localhost:4200
# Network bind. Stays on localhost by default; set HOST=0.0.0.0 only behind
# authentication / a gateway (e.g. in a container).
HOST=127.0.0.1
PORT=8000
