# =============================================================================
# Job Offers Evaluator - environment configuration.
#
# Quick start:  cp .env.example .env
# The values below are a complete, working DEV config: they match the bundled
# docker-compose Postgres and enable development mode, so the demo runs with NO
# edits and NO API keys. For production, see the "PRODUCTION" notes inline and
# the full "Configuration" table in README.md.
#
# NEVER commit your real `.env`.
# =============================================================================

# --- Environment ---
# "development" relaxes the production security checks so the committed dev
# secrets below boot out of the box. Accepted dev values: development/dev/test/local.
# PRODUCTION: set APP_ENV=production (it then refuses to start with the dev
# secrets, non-secure cookies, or wildcard CORS).
APP_ENV=development

# --- Database ---
# Credentials for the docker-compose Postgres (`docker compose up -d db`). The db
# container reads these; DATABASE_URL below points the app at it on localhost.
POSTGRES_USER=offers
POSTGRES_PASSWORD=offers
POSTGRES_DB=offers
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# App-to-Postgres connection. Matches the POSTGRES_* values above (host on localhost).
# The Docker `api`/`seed` services override this to reach Postgres over the compose
# network (@db:5432), so you don't edit it for the pure-Docker path.
DATABASE_URL=postgresql+psycopg://offers:offers@localhost:5432/offers
# Connection-pool sizing (SQLAlchemy defaults). Keep
# WORKERS * (DB_POOL_SIZE + DB_MAX_OVERFLOW) under the database's max connections.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- LLM providers (all optional) ---
# The app boots and the demo works (browse, deterministic match, salary calc) with
# NO keys. AI matching uses a per-user key added later in the UI - not these vars.
# LLM_PROVIDER only selects org-level usage/cost wiring: "gemini" or "openai".
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
# Optional OpenAI admin key (sk-admin-..., scope `api.usage.read`): unlocks the
# authoritative org-spend / org-usage readouts and the org-spend backstop. Users
# can also save their own admin key in-app. Leave blank to disable those readouts.
OPENAI_ADMIN_KEY=

# --- Authentication secrets ---
# DEV DEFAULTS - fine for local (APP_ENV=development). PRODUCTION: override BOTH
# (APP_ENV=production refuses to boot with these committed values).
# JWT_SECRET signs session cookies; use a long (>= 32 char) random secret in prod.
JWT_SECRET=dev-insecure-change-me-0123456789abcdef
# Fernet key encrypting stored provider/admin API keys at rest. Rotating it makes
# existing stored keys undecryptable. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=PG4EqSsP_M6JLdG-_C8nzuzDaj_JsdwAIY9v3ClP0lk=
# Session token lifetimes: short-lived access cookie, longer rotating refresh token.
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
# Login / forgot-password brute-force throttle (per client IP + email).
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
# Throttle backend: "memory" (per-process, single-worker) or "redis" (shared across
# workers). "redis" needs REDIS_URL + `uv sync --extra redis`; required when WORKERS > 1.
RATE_LIMITER_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
# Cookie flags. Local http on same-site localhost uses lax + non-secure.
# PRODUCTION cross-site over https: COOKIE_SECURE=true and COOKIE_SAMESITE=none.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Email (registration confirmation + password reset) ---
# Frontend base URL used to build emailed confirm/reset links.
APP_BASE_URL=http://localhost:4200
# SMTP_HOST empty -> console fallback that only LOGS the link to the API console
# (dev convenience). Set the SMTP_* vars to send real mail (e.g. Mailpit locally:
# SMTP_HOST=localhost, SMTP_PORT=1025, SMTP_USE_TLS=false).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=no-reply@localhost
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1
# MX-check the address at registration (needs DNS). Off by default.
EMAIL_CHECK_DELIVERABILITY=false

# --- AI matching & budgets ---
# Seeds a user's budget limit on first run; afterwards the DB owns it (set via API).
DEFAULT_BUDGET_USD=5.0
# Org-wide daily spend cap for the OpenAI org-spend backstop (all tenants summed;
# active only when an admin key is configured). Defaults to DEFAULT_BUDGET_USD.
ORG_DAILY_BUDGET_USD=5.0
# Block AI matches when spend can't be read (fail-closed). Default false (fail-open).
BUDGET_FAIL_CLOSED=false
# Cache TTLs (seconds) for the per-user spend figure and the available-models list.
BUDGET_SPEND_CACHE_TTL_SECONDS=60.0
MODELS_CACHE_TTL_SECONDS=300.0
# Max offers scored by the AI in parallel per request. Low by default to respect
# free-tier provider limits (e.g. Gemini ~5-10 RPM); raise it on a paid tier.
AI_MATCH_CONCURRENCY=3
# Client-side RPM pacing for Google/Gemini (per user+model). Known models use their
# own free-tier RPM; this is the fallback for unknown models and the kill-switch
# (0 disables Google pacing). OpenAI is never paced.
GOOGLE_RPM_LIMIT=10
# Timeout (seconds) for outbound LLM/provider HTTP calls.
LLM_TIMEOUT_SECONDS=60.0

# --- Server ---
# Network bind. Stays on localhost by default; the Docker `api` service sets
# 0.0.0.0 itself. Only bind 0.0.0.0 behind auth / a gateway.
HOST=127.0.0.1
PORT=8000
# Worker processes. DB-backed state is shared, but the in-memory throttle + caches
# are per-process: for >1 worker set RATE_LIMITER_BACKEND=redis.
WORKERS=1
# Comma-separated allowed CORS origins (the SPA origin). PRODUCTION: list your real
# frontend origin(s); "*" is rejected with credentialed requests.
CORS_ORIGINS=http://localhost:4200

# --- Logging / observability ---
# LOG_LEVEL: DEBUG / INFO / WARNING / ERROR / CRITICAL.
LOG_LEVEL=INFO
# LOG_FORMAT: "console" (human-readable) or "json" (one object per line, for log
# aggregators). Defaults to console in dev / json in production when unset.
LOG_FORMAT=console
# Verbose LLM request/response logging (logs full prompts/PII) - never in production.
LLM_DEBUG=false
