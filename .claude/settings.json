    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.pfx)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",

      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(zsh *)",
      "Bash(fish *)",
      "Bash(cmd *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(uv run python -c *)",
      "Bash(node -e *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(del *)",
      "Bash(find * -delete *)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(env)",
      "Bash(set)",
      "Bash(cat .env*)",
      "Bash(type .env*)",
      "Bash(grep * .env*)",

      "PowerShell(Invoke-WebRequest *)",
      "PowerShell(Invoke-RestMethod *)",
      "PowerShell(curl *)",
      "PowerShell(curl.exe *)",
      "PowerShell(wget *)",
      "PowerShell(powershell *)",
      "PowerShell(pwsh *)",
      "PowerShell(Get-ChildItem Env:*)",
      "PowerShell(Get-Content .env*)",
      "PowerShell(Get-Content *.env*)",
      "PowerShell(Select-String * .env*)"
