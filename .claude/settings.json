{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git check-ignore *)",
      "Bash(npm -v)",
      "Bash(node -v)",
      "Bash(npx --version)",
      "Bash(uv run ruff check *)",
      "Bash(uv run pytest *)",
      "Bash(uv run mypy *)",
      "Bash(uv sync *)",
      "Bash(npm run build *)",
      "Bash(npm run test *)",
      "Bash(npm test *)",
      "Bash(npx tsc *)",
      "Bash(npx ng *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Get-Content *)",
      "PowerShell(Select-String *)",
      "PowerShell(Select-Object *)",
      "PowerShell(Measure-Object *)",
      "PowerShell(uv run *)",
      "PowerShell(git status)",
      "PowerShell(git diff *)"
    ],
    "ask": [
      "Bash(npm install *)",
      "Bash(uv add *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git rm *)",
      "Bash(docker *)",
      "Bash(taskkill *)",
      "Bash(powershell *)",
      "Bash(pwsh *)",
      "PowerShell(git commit *)",
      "PowerShell(git push *)",
      "PowerShell(git reset *)",
      "PowerShell(git clean *)",
      "PowerShell(New-Item *)",
      "PowerShell(Set-Content *)",
      "PowerShell(Move-Item *)",
      "PowerShell(Copy-Item *)",
      "PowerShell(Rename-Item *)",
      "PowerShell(Remove-Item *)",
      "PowerShell(Stop-Process *)",
      "PowerShell(Start-Process *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.pfx)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(node -e *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(del *)",
      "PowerShell(Invoke-WebRequest *)",
      "PowerShell(Invoke-RestMethod *)",
      "PowerShell(curl *)",
      "PowerShell(curl.exe *)",
      "PowerShell(wget *)",
      "PowerShell(powershell *)",
      "PowerShell(pwsh *)"
    ]
  }
}